# Control Plane 환경설정 예시 — 복사해서 deploy/.env 로 채운다 (커밋 금지).

# 외부 접근 주소 (에이전트·install.sh가 보는 CP 주소)
CP_PUBLIC_URL=https://cp.example.com

# PostgreSQL
PG_USER=xgen
PG_PASSWORD=change-me
PG_DB=orchestrator

# MinIO (번들 저장)
MINIO_USER=xgen
MINIO_PASSWORD=change-me

# CP 마스터 암호화 키(KEK) — 시크릿 app-level 암호화 (12-operational-policies.md).
# 파일 경로(권장, 0600) 또는 직접 값. 분실 시 모든 시크릿 복구 불가 — 백업 필수.
CP_MASTER_KEY_FILE=/var/lib/xgen-cp/master.key

# 내부 CA (노드 cert 서명) — 부팅 시 생성/로드
CP_CA_DIR=/var/lib/xgen-cp/ca

# 번들 서명 검증용 cosign 공개키 (에이전트 배포분 기준)
COSIGN_PUBLIC_KEY=/var/lib/xgen-cp/cosign.pub
