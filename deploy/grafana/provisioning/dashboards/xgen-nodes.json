{
  "uid": "xgen-nodes",
  "title": "XGEN Orchestrator — Nodes",
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Nodes up",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [ { "expr": "sum(xgen_node_up)", "refId": "A" } ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory used (bytes) by node",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "targets": [ { "expr": "xgen_mem_used_bytes", "legendFormat": "{{node_id}}", "refId": "A" } ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "GPU utilization (%)",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [ { "expr": "xgen_gpu_utilization_percent", "legendFormat": "{{node_id}} gpu{{gpu}}", "refId": "A" } ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GPU memory used (bytes)",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [ { "expr": "xgen_gpu_mem_used_bytes", "legendFormat": "{{node_id}} gpu{{gpu}}", "refId": "A" } ]
    }
  ]
}
